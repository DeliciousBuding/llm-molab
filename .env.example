# Copy to /tmp/.secrets/*.env inside sandbox — never commit real values.

# Hugging Face (download)
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Inference API key (generate with secrets.token_urlsafe)
LLM_API_KEY=

# Optional: override model path / ports
MODEL_PATH=/marimo/models/Qwen3.6-35B-A3B-FP8
SERVE_HOST=127.0.0.1
SERVE_PORT=8000

# Cloudflare tunnel (token mode preferred for temp tunnels)
# Put raw token in /tmp/.secrets/tunnel.token instead of this file when possible.
TUNNEL_TOKEN=
TUNNEL_HOSTNAME=llm.vectorcontrol.tech
