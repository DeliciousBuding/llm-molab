# Durable serve defaults — NO secrets. Copied to /marimo/llm-lab/state/serve.env
# Package-first: all large artifacts under /marimo for remint reuse when quota allows.

MODEL_PATH=/marimo/models/Qwen3.6-35B-A3B-FP8
SERVED_MODEL_NAME=Qwen3.6-35B-A3B-FP8
SERVE_HOST=127.0.0.1
SERVE_PORT=8000
SERVE_MODE=baseline
CONTEXT_LENGTH=32768
MEM_FRACTION_STATIC=0.80
CHUNKED_PREFILL_SIZE=8192
KV_CACHE_DTYPE=
ENABLE_MTP=0
MTP_STEPS=3
MTP_TOPK=1
MTP_DRAFT_TOKENS=4
TUNNEL_HOSTNAME=llm.vectorcontrol.tech
LLM_LAB=/marimo/llm-lab
REPO_DIR=/marimo/work/llm-molab
ENGINE=vllm
