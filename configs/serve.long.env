# Profile: long — 128K candidate with FP8 KV (A/B quality before defaulting)
# NO secrets. Only promote after scripts/20_bench.py S6/S8 pass.

MODEL_PATH=/marimo/models/Qwen3.6-35B-A3B-FP8
SERVED_MODEL_NAME=Qwen3.6-35B-A3B-FP8
SERVE_HOST=127.0.0.1
SERVE_PORT=8000
SERVE_MODE=long
CONTEXT_LENGTH=131072
MEM_FRACTION_STATIC=0.88
CHUNKED_PREFILL_SIZE=8192
KV_CACHE_DTYPE=fp8
MAX_NUM_SEQS=16
ENABLE_MTP=0
MTP_STEPS=3
MTP_TOPK=1
MTP_DRAFT_TOKENS=4
ENABLE_PREFIX_CACHING=1
TUNNEL_HOSTNAME=llm.vectorcontrol.tech
LLM_LAB=/marimo/llm-lab
REPO_DIR=/marimo/work/llm-molab
ENGINE=vllm
