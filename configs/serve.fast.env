# Profile: fast — more KV / concurrency, still 32K, no MTP yet
# NO secrets. Apply: bash scripts/16_apply_profile.sh fast && bash scripts/05b_serve_vllm.sh

MODEL_PATH=/marimo/models/Qwen3.6-35B-A3B-FP8
SERVED_MODEL_NAME=Qwen3.6-35B-A3B-FP8
SERVE_HOST=127.0.0.1
SERVE_PORT=8000
SERVE_MODE=fast
CONTEXT_LENGTH=32768
MEM_FRACTION_STATIC=0.88
CHUNKED_PREFILL_SIZE=8192
KV_CACHE_DTYPE=
MAX_NUM_SEQS=32
ENABLE_MTP=0
MTP_STEPS=3
MTP_TOPK=1
MTP_DRAFT_TOKENS=4
ENABLE_PREFIX_CACHING=1
TUNNEL_HOSTNAME=llm.vectorcontrol.tech
LLM_LAB=/marimo/llm-lab
REPO_DIR=/marimo/work/llm-molab
ENGINE=vllm
